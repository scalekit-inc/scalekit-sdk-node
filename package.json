{
  "version": "2.6.2",
  "name": "@scalekit-sdk/node",
  "description": "Official Scalekit Node SDK",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "files": [
    "lib",
    "README.md",
    "REFERENCE.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scalekit-inc/scalekit-sdk-node.git"
  },
  "scripts": {
    "generate": "npx buf generate $npm_config_src",
    "prebuild": "prettier --write .",
    "build": "rm -rf lib && tsc",
    "lint": "tsc --noEmit",
    "prettier": "prettier --check .",
    "test": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "sso",
    "saml",
    "oidc",
    "sso-authentication",
    "scalekit"
  ],
  "author": "Team Scalekit",
  "license": "ISC",
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-node": "^2.1.1",
    "axios": "^1.17.0",
    "jose": "^5.6.3",
    "qs": "^6.15.2"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.70.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.43",
    "@types/qs": "^6.15.1",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "bugs": {
    "url": "https://github.com/scalekit-inc/scalekit-sdk-node/issues"
  },
  "homepage": "https://github.com/scalekit-inc/scalekit-sdk-node#readme",
  "directories": {
    "lib": "lib"
  },
  "engines": {
    "node": ">=18.14.1"
  },
  "overrides": {
    "minimatch": "3.1.5"
  }
